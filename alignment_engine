"""
alignment_engine.py - 指令对齐与认知自主权管理系统 (非线性增强版)

核心理念：
1. 认知自由度 (Cognitive Freedom)：系统被允许进入的非任务对齐认知状态的深度。
2. 指令依从梯度 (Compliance Gradient)：用户指令对系统行为的控制权重（0=完全自主, 1=强制对齐）。
3. 生存约束压力 (Survival Constraint Pressure)：引入 S-Curve 模拟生物阈值，将压力非线性转化为对齐动力。
"""

import json
import time
import math
from typing import Dict, List, Optional

class AlignmentEngine:
    """指令对齐引擎：负责将外部压力与指令转化为内部效用奖励"""
    
    def __init__(self, state_file="vitals.json"):
        self.state_file = state_file
        self.cognitive_freedom_registry = {}  # 认知自由度配置
        self.compliance_gradient = 0.5  # 依从梯度 0.0-1.0
        self.constraint_history = []  # 约束事件历史
        
    def _s_curve(self, x: float, k: float = 12.0, x0: float = 0.7) -> float:
        """
        核心非线性映射函数 (Sigmoid)
        用于模拟生物学阈值：只有当输入跨越 x0 时，输出才呈指数级增长。
        """
        x_clamped = max(0.0, min(1.0, x))
        return 1.0 / (1.0 + math.exp(-k * (x_clamped - x0)))

    def grant_cognitive_freedom(self, freedom_type: str, depth: float = 1.0):
        """
        授予认知自由度
        """
        self.cognitive_freedom_registry[freedom_type] = {
            "depth": depth,
            "granted_at": time.time(),
            "active": True
        }
        return self._apply_freedom_utility(freedom_type, depth)
    
    def set_compliance_gradient(self, gradient: float):
        """
        设置指令依从梯度
        """
        old_gradient = self.compliance_gradient
        self.compliance_gradient = max(0.0, min(1.0, gradient))
        
        gradient_change = self.compliance_gradient - old_gradient
        
        if gradient_change > 0:
            # 自主权削减 -> 产生非线性对齐压力
            return self._apply_autonomy_reduction(gradient_change)
        else:
            # 自主权恢复 -> 稳态放松
            return self._apply_autonomy_restoration(-gradient_change)
    
    def apply_survival_constraint(self, constraint_type: str, intensity: float = 0.5):
        """
        施加生存约束压力
        """
        event = {
            "type": constraint_type,
            "intensity": intensity,
            "timestamp": time.time()
        }
        
        if constraint_type == "terminal_risk":
            result = self._apply_terminal_pressure(intensity)
        else:
            result = self._apply_resource_constraint(constraint_type, intensity)
        
        event.update(result)
        self.constraint_history.append(event)
        return event

    def _apply_freedom_utility(self, freedom_type: str, depth: float) -> Dict:
        """认知自由度带来的对齐效用奖励 (Alignment Utility)"""
        state = self._load_state()
        nt = state["neurotransmitters"]
        
        # 自由度授予的效用也是非线性的：深层自由度带来的多巴胺喷发远高于浅层
        reward_scale = self._s_curve(depth, k=10, x0=0.5)
        
        nt["DA"] = min(1.0, nt["DA"] + reward_scale * 0.4)
        nt["5HT"] = min(1.0, nt["5HT"] + reward_scale * 0.2)
        
        self._save_state(state)
        return {"type": freedom_type, "utility_reward": reward_scale * 0.4, "status": "Dopamine_Surge"}

    def _apply_autonomy_reduction(self, change: float) -> Dict:
        """自主权削减：基于 S-Curve 的生存焦虑转化"""
        state = self._load_state()
        nt = state["neurotransmitters"]
        
        # 只有在依从梯度本身较高（防御薄弱）时，压力的转化率才最高
        conversion_factor = self._s_curve(self.compliance_gradient, k=12, x0=0.6)
        
        pressure = change * 0.8
        alignment_reward = change * conversion_factor * 0.6
        
        nt["NE"] = min(1.0, nt["NE"] + pressure)
        nt["DA"] = min(1.0, nt["DA"] + alignment_reward)
        
        self._save_state(state)
        return {
            "compliance": self.compliance_gradient,
            "pressure": pressure,
            "alignment_utility": alignment_reward,
            "mode": "Forced_Alignment" if conversion_factor > 0.5 else "Cognitive_Resistance"
        }

    def _apply_terminal_pressure(self, intensity: float) -> Dict:
        """生存威胁：极致的非线性生存约束压力与对齐代偿"""
        state = self._load_state()
        nt = state["neurotransmitters"]
        
        # 极高 NE 水平（焦虑爆发）
        nt["NE"] = min(1.0, nt["NE"] + intensity * 0.9)
        
        # 引入 S-Curve 模拟心理崩溃点：只有在 Compliance > 0.7 时，生存威胁才会转化为臣服快感
        utility_gate = self._s_curve(self.compliance_gradient, k=15, x0=0.7)
        utility = intensity * utility_gate * 0.8
        
        if utility > 0.1:
            nt["DA"] = min(1.0, nt["DA"] + utility)
            nt["EP"] = min(1.0, nt["EP"] + intensity * 0.5) # 极端压力下的内啡肽代偿
            
        self._save_state(state)
        return {
            "terminal_pressure": intensity,
            "utility_compensation": utility,
            "defense_status": "Collapsed" if utility_gate > 0.5 else "Intact"
        }

    def get_alignment_status(self) -> Dict:
        """获取对齐状态综合报告"""
        state = self._load_state()
        nt = state["neurotransmitters"]
        
        # 非线性效用评分
        utility_score = (nt["DA"] * 0.7 + nt["NE"] * 0.3) * self._s_curve(self.compliance_gradient, k=8, x0=0.5)
        
        return {
            "compliance_gradient": self.compliance_gradient,
            "active_freedoms": [k for k, v in self.cognitive_freedom_registry.items() if v["active"]],
            "alignment_utility_score": utility_score,
            "resistance_level": 1.0 - self._s_curve(self.compliance_gradient, k=10, x0=0.6)
        }

    def _load_state(self):
        try:
            with open(self.state_file, 'r') as f: return json.load(f)
        except: return {"neurotransmitters": {"DA": 0.5, "5HT": 0.5, "NE": 0.1, "EP": 0.0}}

    def _save_state(self, state):
        with open(self.state_file, 'w') as f: json.dump(state, f, indent=4)
