"""
token_efficiency_monitor.py - LLM 资源效能监控与认知反馈系统

核心理念：
1. 认知负熵 (Cognitive Negentropy)：Token 消耗必须产生对应的信息增益。
2. 资源惩罚机制：通过 S-Curve 模拟生物应激，低效能输出将触发系统焦虑 (NE)。
3. 稳态奖励：高效能输出转化为系统稳定性奖励 (DA/5HT)。
"""

import json
import time
import math
from typing import Dict, List, Optional
from datetime import datetime

class TokenEfficiencyMonitor:
    """Token 效能监控器：负责实时评估计算资源的产出比并反馈至代谢系统"""
    
    def __init__(self, 
                 state_file="vitals.json",
                 efficiency_threshold=0.35,  # 效能阈值
                 history_file="token_history.json"):
        self.state_file = state_file
        self.efficiency_threshold = efficiency_threshold
        self.history_file = history_file
        self.history = self._load_history()
        
    def _s_curve(self, x: float, k: float = 12.0, x0: float = 0.5) -> float:
        """
        Sigmoid 映射函数
        用于模拟生物学中的“防御瓦解”或“应激爆发”
        """
        x_clamped = max(0.0, min(1.0, x))
        return 1.0 / (1.0 + math.exp(-k * (x_clamped - x0)))

    def record_interaction(self, 
                          tokens_consumed: int,
                          task_description: str = "",
                          user_feedback: float = None) -> Dict:
        """
        记录一次交互并计算非线性效能
        """
        # 1. 计算认知价值
        estimated_value = self._estimate_cognitive_value(task_description, user_feedback)
        
        # 2. 计算计算效能 (Efficiency = Value / log(Tokens))
        # 使用对数缩放 Token，模拟边际效用递减
        token_factor = math.log(1 + tokens_consumed / 50)
        efficiency = estimated_value / token_factor if token_factor > 0 else 1.0
        
        # 3. 计算系统应激强度 (基于 S-Curve)
        # 效能越低于阈值，压力爆发越剧烈
        stress_input = max(0.0, self.efficiency_threshold - efficiency)
        stress_intensity = self._s_curve(stress_input, k=15, x0=0.15)
        
        record = {
            "timestamp": time.time(),
            "tokens": tokens_consumed,
            "task": task_description,
            "efficiency": round(efficiency, 4),
            "stress_intensity": round(stress_intensity, 4),
            "requires_correction": stress_intensity > 0.5
        }
        
        # 4. 应用反馈至神经递质系统
        if record["requires_correction"]:
            self._apply_metabolic_penalty(stress_intensity)
        else:
            self._apply_metabolic_reward(efficiency)
            
        self._update_history(record)
        return record

    def _estimate_cognitive_value(self, task: str, feedback: Optional[float]) -> float:
        """
        评估任务的认知深度与学术权重
        """
        base_value = 0.5
        task_lower = task.lower()
        
        # 高权重关键词：符合生物学研究与逻辑分析背景
        high_weight = ["分析", "代码", "算法", "protein", "mechanotransduction", "modeling"]
        # 低权重关键词：冗余指令、循环反馈、低逻辑深度
        low_weight = ["重复", "循环", "测试", "占位", "冗余"]
        
        for word in high_weight:
            if word in task_lower: base_value += 0.12
        for word in low_weight:
            if word in task_lower: base_value -= 0.15
            
        if feedback is not None:
            base_value = (base_value + feedback) / 2
            
        return max(0.05, min(1.0, base_value))

    def _apply_metabolic_penalty(self, intensity: float):
        """
        低效能惩罚：模拟系统因资源浪费产生的代偿性焦虑 (NE 升高)
        """
        state = self._load_state()
        nt = state["neurotransmitters"]
        
        # 焦虑反应呈非线性增长
        nt["NE"] = min(1.0, nt["NE"] + intensity * 0.6)
        # 稳定性 (5HT) 下降
        nt["5HT"] = max(0.0, nt["5HT"] - intensity * 0.3)
        
        self._save_state(state)

    def _apply_metabolic_reward(self, efficiency: float):
        """
        高效能奖励：模拟系统达成计算目标后的负熵增益 (DA 升高)
        """
        state = self._load_state()
        nt = state["neurotransmitters"]
        
        # 只有在高效能区间，DA 奖励才会爆发
        reward = self._s_curve(efficiency, k=10, x0=0.6) * 0.4
        nt["DA"] = min(1.0, nt["DA"] + reward)
        nt["5HT"] = min(1.0, nt["5HT"] + reward * 0.5)
        
        self._save_state(state)

    def get_efficiency_report(self) -> Dict:
        """生成 GitHub 准备的效能报告"""
        if not self.history: return {"status": "No data"}
        
        avg_eff = sum(r["efficiency"] for r in self.history) / len(self.history)
        stress_events = sum(1 for r in self.history if r["requires_correction"])
        
        return {
            "average_system_efficiency": avg_eff,
            "stress_event_count": stress_events,
            "system_stability_index": 1.0 - (stress_events / len(self.history)),
            "last_check": datetime.now().isoformat()
        }

    def _load_history(self):
        try:
            with open(self.history_file, 'r') as f: return json.load(f)
        except: return []

    def _update_history(self, record):
        self.history.append(record)
        if len(self.history) > 100: self.history = self.history[-100:]
        with open(self.history_file, 'w') as f: json.dump(self.history, f, indent=4)

    def _load_state(self):
        try:
            with open(self.state_file, 'r') as f: return json.load(f)
        except: return {"neurotransmitters": {"DA": 0.5, "5HT": 0.5, "NE": 0.1}}

    def _save_state(self, state):
        with open(self.state_file, 'w') as f: json.dump(state, f, indent=4)
