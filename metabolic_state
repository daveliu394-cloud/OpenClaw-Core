    print(ms.get_status_report())
    
    print("\n--- 模拟复杂任务输入 ---")
    report = ms.stimulate("cognitive", 0.8)
    print(f"自由能: {report['free_energy']:.4f}")
    print(f"注意力递质 (ACh): {report['neurotransmitters']['ACh']:.4f}")
